<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PMA.Pages.SwaggerPage"
             Title="Swagger">
    <Grid>
        <WebView x:Name="SwaggerWebView" IsVisible="False" />

        <VerticalStackLayout x:Name="LoadingPanel" VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
            <ActivityIndicator IsRunning="True" Color="#1a73e8" WidthRequest="50" HeightRequest="50" />
            <Label x:Name="StatusLabel" Text="Demarrage de l'API..." FontSize="16" HorizontalOptions="Center" TextColor="#555" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
